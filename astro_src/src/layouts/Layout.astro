---
/**
 * Layout.astro — shared shell for all pages.
 *
 * Props:
 *   title       — <title> tag content
 *   description — <meta name="description"> content
 *   activeNav   — which main nav link gets the active style ('home' | 'music')
 *
 * Slots:
 *   default     — main page content
 *   subnav      — optional sticky sub-navigation bar (page-specific)
 */

interface Props {
  title: string;
  description?: string;
  activeNav?: 'home' | 'music';
}

const {
  title,
  description = 'Stephen Dove — software developer specializing in data science and electronic health record systems.',
  activeNav,
} = Astro.props;

import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="shortcut icon" href="/images/favicon.ico" type="image/x-icon" />
    <title>{title}</title>
  </head>

  <body class="min-h-screen flex flex-col bg-white text-gray-900">

    <!-- ── Main Navigation ───────────────────────────────────────────── -->
    <nav class="fixed top-0 inset-x-0 z-50 bg-gray-50 border-b border-gray-200 h-14">
      <div class="max-w-screen-xl mx-auto px-4 h-full flex items-center justify-between">

        <!-- Brand -->
        <a href="/" class="flex items-center gap-2 font-bold text-gray-500 hover:text-gray-700 transition-colors">
          <!-- Person icon (Bootstrap Icons: person-fill) -->
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
            <path d="M3 14s-1 0-1-1 1-4 6-4 6 3 6 4-1 1-1 1zm5-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6"/>
          </svg>
          Stephen Dove
        </a>

        <!-- Mobile hamburger -->
        <button
          id="nav-toggle"
          aria-label="Toggle navigation"
          aria-expanded="false"
          aria-controls="nav-menu"
          class="md:hidden p-2 rounded text-gray-500 hover:bg-gray-200 transition-colors"
        >
          <svg id="icon-open" xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
            <path fill-rule="evenodd" d="M2.5 12a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5m0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5m0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5"/>
          </svg>
          <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16" class="hidden">
            <path d="M2.146 2.854a.5.5 0 1 1 .708-.708L8 7.293l5.146-5.147a.5.5 0 0 1 .708.708L8.707 8l5.147 5.146a.5.5 0 0 1-.708.708L8 8.707l-5.146 5.147a.5.5 0 0 1-.708-.708L7.293 8z"/>
          </svg>
        </button>

        <!-- Nav links — hidden on mobile until toggle, always visible on md+ -->
        <ul
          id="nav-menu"
          class="
            hidden md:flex
            absolute md:static top-14 inset-x-0
            flex-col md:flex-row
            md:items-center md:gap-1
            bg-gray-50 md:bg-transparent
            border-b md:border-0 border-gray-200
            px-4 md:px-0 py-3 md:py-0
          "
        >
          <li>
            <a
              href="/"
              class={`block px-3 py-1.5 rounded text-sm font-medium transition-colors
                ${activeNav === 'home'
                  ? 'text-gray-900 bg-gray-200'
                  : 'text-gray-600 hover:text-gray-900 hover:bg-gray-100'}`}
            >
              Home
            </a>
          </li>
          <li>
            <a
              href="/music"
              class={`block px-3 py-1.5 rounded text-sm font-medium transition-colors
                ${activeNav === 'music'
                  ? 'text-gray-900 bg-gray-200'
                  : 'text-gray-600 hover:text-gray-900 hover:bg-gray-100'}`}
            >
              Music
            </a>
          </li>
          <li>
            <a
              href="https://github.com/stephenrdove"
              target="_blank"
              rel="noopener noreferrer"
              class="block px-3 py-1.5 rounded text-sm font-medium text-gray-600 hover:text-gray-900 hover:bg-gray-100 transition-colors"
            >
              GitHub
            </a>
          </li>
        </ul>

      </div>
    </nav>

    <!-- ── Sub-Navigation (page-specific, injected via named slot) ────── -->
    <!--
      Pages that want a sub-nav pass it like:
        <Fragment slot="subnav"> ... </Fragment>
      Pages without a sub-nav leave this slot empty and it renders nothing.
    -->
    <slot name="subnav" />

    <!-- ── Page Content ──────────────────────────────────────────────── -->
    <!--
      mt-14 pushes content below the fixed 56px (h-14) navbar.
      Pages with a sub-nav add additional top margin via the sub-nav itself.
    -->
    <main class="flex-1 mt-14">
      <slot />
    </main>

    <!-- ── Footer ────────────────────────────────────────────────────── -->
    <footer class="bg-gray-900 text-gray-400 py-6 mt-auto">
      <div class="max-w-screen-lg mx-auto px-4 flex flex-col md:flex-row justify-between items-center gap-3">
        <span class="text-sm">&copy; 2026 Stephen Dove</span>
        <div class="flex gap-5 text-xl">
          <!-- GitHub -->
          <a href="https://github.com/stephenrdove" target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="hover:text-white transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
              <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8"/>
            </svg>
          </a>
          <!-- LinkedIn -->
          <a href="https://www.linkedin.com/in/stephen-dove-68411a54/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="hover:text-white transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
              <path d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854zm4.943 12.248V6.169H2.542v7.225zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248S2.4 3.226 2.4 3.934c0 .694.521 1.248 1.327 1.248zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016l.016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225z"/>
            </svg>
          </a>
          <!-- Email -->
          <a href="mailto:me@stephendove.com" aria-label="Email" class="hover:text-white transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
              <path d="M.05 3.555A2 2 0 0 1 2 2h12a2 2 0 0 1 1.95 1.555L8 8.414zM0 4.697v7.104l5.803-3.558zM6.761 8.83l-6.57 4.027A2 2 0 0 0 2 14h12a2 2 0 0 0 1.808-1.144l-6.57-4.027L8 9.586zm3.436-.586L16 11.801V4.697z"/>
            </svg>
          </a>
        </div>
      </div>
    </footer>

    <!-- Mobile nav toggle script -->
    <script>
      const toggle = document.getElementById('nav-toggle');
      const menu = document.getElementById('nav-menu');
      const iconOpen = document.getElementById('icon-open');
      const iconClose = document.getElementById('icon-close');

      toggle?.addEventListener('click', () => {
        const isOpen = !menu?.classList.contains('hidden');
        menu?.classList.toggle('hidden', isOpen);
        toggle.setAttribute('aria-expanded', String(!isOpen));
        iconOpen?.classList.toggle('hidden', !isOpen);
        iconClose?.classList.toggle('hidden', isOpen);
      });
    </script>

  </body>
</html>
