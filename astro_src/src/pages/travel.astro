---

<Layout
  title="Stephen Dove — Travel"
  description="Stephen Dove — travel across the US."
  activeNav="travel"
>

  <!-- Sub-nav -->
  <nav slot="subnav" class="hidden md:block sticky top-14 z-40 bg-gray-50 border-b border-gray-200 py-2">
    <div class="max-w-screen-xl mx-auto px-4">
      <ul class="flex justify-center gap-1">
        <li>
          <a href="/#about" class="px-3 py-1.5 rounded text-sm font-medium text-gray-600 hover:text-gray-900 hover:bg-gray-100 transition-colors">About</a>
        </li>
        <li>
          <a href="/#cv" class="px-3 py-1.5 rounded text-sm font-medium text-gray-600 hover:text-gray-900 hover:bg-gray-100 transition-colors">CV</a>
        </li>
        <li>
          <a href="/#interests" class="px-3 py-1.5 rounded text-sm font-medium text-gray-600 hover:text-gray-900 hover:bg-gray-100 transition-colors">Interests</a>
        </li>
      </ul>
    </div>
  </nav>

  <section class="py-16 px-4 [scroll-margin-top:110px]">
    <div class="max-w-screen-lg mx-auto">
      <h1 class="text-4xl font-bold text-center text-gray-800 mb-2">Travel</h1>
      <p class="text-center text-gray-500 mb-10">Hover a state to see its name. Click for details.</p>

      <!-- Map + panel wrapper -->
      <div class="relative">

        <!-- D3 renders the SVG into this div.
             State data is passed via data attributes — Astro auto-escapes
             the JSON so it's safe to embed in an HTML attribute. -->
        <div
          id="map-container"
          class="w-full"
          data-states={JSON.stringify(stateData)}
          data-fips={JSON.stringify(fipsToAbbr)}
        ></div>

        <!-- Tooltip — follows the cursor, shown on state hover -->
        <div
          id="map-tooltip"
          class="fixed z-50 pointer-events-none hidden bg-gray-900 text-white text-xs font-medium px-2.5 py-1.5 rounded-lg shadow-lg"
        ></div>

        <!-- Side panel — slides in from the right on state click -->
        <div
          id="state-panel"
          class="fixed top-14 right-0 h-[calc(100vh-56px)] w-80 bg-white shadow-2xl border-l border-gray-200 translate-x-full transition-transform duration-300 ease-in-out z-40 flex flex-col"
        >
          <div class="flex items-center justify-between p-5 border-b border-gray-100">
            <h2 id="panel-state-name" class="text-xl font-bold text-gray-800"></h2>
            <button
              id="panel-close"
              aria-label="Close panel"
              class="p-1.5 rounded-lg text-gray-400 hover:text-gray-600 hover:bg-gray-100 transition-colors"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/>
              </svg>
            </button>
          </div>
          <div class="flex-1 overflow-y-auto p-5">
            <p id="panel-notes" class="text-gray-600 text-sm leading-relaxed"></p>
            <p id="panel-empty" class="text-gray-400 text-sm italic hidden">No notes yet for this state.</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <script>
    /**
     * D3 US map — rendered client-side.
     *
     * d3-geo provides:
     *   - geoAlbersUsa(): a composite projection that places Alaska (scaled)
     *     and Hawaii as insets bottom-left, matching every standard US map.
     *   - geoPath(): converts GeoJSON feature objects to SVG path strings.
     *
     * topojson-client converts the compact TopoJSON format from us-atlas into
     * standard GeoJSON that D3 can work with.
     *
     * State data is read from data attributes on the map container, which
     * Astro serializes safely at build time.
     */
    import * as d3 from 'd3';
    import * as topojson from 'topojson-client';
    // @ts-ignore — us-atlas ships a JSON file without types
    import us from 'us-atlas/states-10m.json';

    // Read data from the container's data attributes (set by Astro at build time)
    const container  = document.getElementById('map-container')!;
    const stateData  = JSON.parse(container.dataset.states!);
    const fipsToAbbr = JSON.parse(container.dataset.fips!);

    // ── Build the map ──────────────────────────────────────────────────

    const tooltip    = document.getElementById('map-tooltip')!;
    const panel      = document.getElementById('state-panel')!;
    const panelName  = document.getElementById('panel-state-name')!;
    const panelNotes = document.getElementById('panel-notes')!;
    const panelEmpty = document.getElementById('panel-empty')!;
    const panelClose = document.getElementById('panel-close')!;

    // Responsive: fit the projection to the container width.
    // Fall back to 800 if clientWidth is 0 (shouldn't happen but safe).
    const width  = container.clientWidth || 800;
    const height = Math.round(width * 0.625); // standard Albers USA aspect ratio

    const usGeo = us as unknown as Topology;
    const states = topojson.feature(usGeo, usGeo.objects.states as any) as any;
    const mesh   = topojson.mesh(usGeo, usGeo.objects.states as any, (a, b) => a !== b);

    const projection = d3.geoAlbersUsa().fitSize([width, height], states);
    const path       = d3.geoPath().projection(projection);

    const svg = d3.select('#map-container')
      .append('svg')
      .attr('viewBox', `0 0 ${width} ${height}`)
      .attr('preserveAspectRatio', 'xMidYMid meet')
      .style('width', '100%')
      .style('height', 'auto');

    // State fills
    svg.selectAll('path.state')
      .data(states.features)
      .join('path')
        .attr('class', 'state')
        .attr('d', path as any)
        .attr('fill', '#93c5fd')       // blue-300
        .attr('stroke', 'none')
        .style('cursor', 'pointer')
        .style('transition', 'fill 0.15s')
      .on('mouseover', function (event, d: any) {
        const abbr  = fipsToAbbr[String(d.id).padStart(2, '0')];
        const state = stateData[abbr];
        if (!state) return;

        d3.select(this).attr('fill', '#3b82f6'); // blue-500 on hover

        tooltip.textContent = state.name;
        tooltip.classList.remove('hidden');
      })
      .on('mousemove', function (event: MouseEvent) {
        tooltip.style.left = `${event.clientX + 12}px`;
        tooltip.style.top  = `${event.clientY - 28}px`;
      })
      .on('mouseout', function () {
        d3.select(this).attr('fill', function(d: any) {
          const abbr = fipsToAbbr[String((d as any).id).padStart(2, '0')];
          return selectedAbbr === abbr ? '#2563eb' : '#93c5fd'; // keep selected blue
        });
        tooltip.classList.add('hidden');
      })
      .on('click', function (_event: MouseEvent, d: any) {
        const abbr  = fipsToAbbr[String(d.id).padStart(2, '0')];
        const state = stateData[abbr];
        if (!state) return;

        // Reset previous selection
        svg.selectAll('path.state').attr('fill', '#93c5fd');
        // Highlight selected
        d3.select(this).attr('fill', '#2563eb'); // blue-600
        selectedAbbr = abbr;

        openPanel(state.name, state.notes);
      });

    // State borders (drawn as a mesh so interior borders don't double-stroke)
    svg.append('path')
      .datum(mesh)
      .attr('d', path as any)
      .attr('fill', 'none')
      .attr('stroke', 'white')
      .attr('stroke-width', 0.5);

    // ── Panel ──────────────────────────────────────────────────────────

    let selectedAbbr = '';

    function openPanel(name: string, notes: string) {
      panelName.textContent  = name;
      panelNotes.textContent = notes;

      if (notes) {
        panelNotes.classList.remove('hidden');
        panelEmpty.classList.add('hidden');
      } else {
        panelNotes.classList.add('hidden');
        panelEmpty.classList.remove('hidden');
      }

      panel.classList.remove('translate-x-full');
    }

    function closePanel() {
      panel.classList.add('translate-x-full');
      svg.selectAll('path.state').attr('fill', '#93c5fd');
      selectedAbbr = '';
    }

    panelClose.addEventListener('click', closePanel);

    // Close panel on Escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closePanel();
    });
  </script>

</Layout>
