  <!--
    Vanilla JS for the Top 100 expand/collapse toggles.
    In Astro, <script> tags are bundled by Vite — they run in the browser
    (unlike the frontmatter --- block which runs at build time).

    The pattern:
      - Collapsible elements have data-collapse-group="<name>"
      - Toggle buttons have data-toggle-group="<name>"
      - Clicking the button toggles "hidden" on all matching elements,
        flips aria-expanded, and updates the label/chevron.
  -->
  <script>
    document.querySelectorAll<HTMLButtonElement>('[data-toggle-group]').forEach(button => {
      button.addEventListener('click', () => {
        const group = button.dataset.toggleGroup!;
        const targets = document.querySelectorAll<HTMLElement>(`[data-collapse-group="${group}"]`);
        const grid = document.querySelector<HTMLElement>(`[data-grid="${group}"]`);
        const isExpanded = button.getAttribute('aria-expanded') === 'true';

        targets.forEach(el => el.classList.toggle('hidden', isExpanded));
        grid?.classList.toggle('expanded', !isExpanded);
        button.setAttribute('aria-expanded', String(!isExpanded));

        button.querySelector<HTMLElement>('.label-more')!.classList.toggle('hidden', !isExpanded);
        button.querySelector<HTMLElement>('.label-less')!.classList.toggle('hidden', isExpanded);
        button.querySelector<HTMLElement>('.chevron')!.style.transform = isExpanded ? '' : 'rotate(180deg)';
      });
    });
  </script>

